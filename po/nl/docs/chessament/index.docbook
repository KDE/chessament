		<sect1 id="reference-command-line-options">
			<title
>Opdrachtregel-opties</title>
			<variablelist>
			  <varlistentry>
					<term>
						<userinput
><command
>chessament</command
> <option
>--import-trf <replaceable
>bestand</replaceable
></option
> </userinput>
					</term>
					<listitem>
						<para
>Importeer een Toernooirapportbestand (<acronym
>TRF</acronym
>) als een nieuw toernooi. </para>
					</listitem>
