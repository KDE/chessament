      <abstract>
        <para
>&chessament; — програма для керування шаховими турнірами. </para>
      </abstract>
    <keywordset>
      <keyword
>KDE</keyword>
      <keyword
>Chessament</keyword>
			<keyword
>шахи</keyword>
			<keyword
>турнір</keyword>
    </keywordset>
