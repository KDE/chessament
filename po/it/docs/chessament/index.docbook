		<sect1 id="reference-command-line-options">
			<title
>Opzioni per riga di comando</title>
			<variablelist>
			  <varlistentry>
					<term>
						<userinput
><command
>chessament</command
> <option
>--import-trf <replaceable
>file</replaceable
></option
> </userinput>
					</term>
					<listitem>
						<para
>Importa un file di resoconto di un torneo (<acronym
>TRF</acronym
>) come nuovo torneo. </para>
					</listitem>
			  </varlistentry>
			</variablelist>
		</sect1>
	</chapter>

