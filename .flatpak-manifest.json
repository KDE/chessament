{
    "$schema": "https://raw.githubusercontent.com/flatpak/flatpak-builder/main/data/flatpak-manifest.schema.json",
    "id": "org.kde.chessament",
    "branch": "master",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "chessament",
    "tags": [
        "nightly"
    ],
    "desktop-file-name-suffix": " (Nightly)",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "separate-locales": false,
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/mkspecs",
        "/share/doc"
    ],
    "modules": [
        {
            "name": "qtkeychain",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/frankosterfeld/qtkeychain/archive/refs/tags/0.15.0.tar.gz",
                    "sha256": "f4254dc8f0933b06d90672d683eab08ef770acd8336e44dfa030ce041dc2ca22"
                }
            ],
            "config-opts": [
                "-DBUILD_WITH_QT6=ON",
                "-DCMAKE_INSTALL_LIBDIR=/app/lib",
                "-DLIB_INSTALL_DIR=/app/lib",
                "-DBUILD_TRANSLATIONS=NO",
                "-DBUILD_TESTING=OFF"
            ]
        },
        {
            "name": "bbpPairings",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/BieremaBoyzProgramming/bbpPairings/archive/refs/tags/v6.0.0.tar.gz",
                    "sha256": "b7f95c0803131e38a56e8829bd062d9ad51908322dd6fef01380b2f612f58227"
                },
                {
                    "type": "patch",
                    "path": "0001-Add-CMake-build.patch"
                }
            ]
        },
        {
            "name": "chessament",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "dir",
                    "path": ".",
                    "skip": [
                        ".git"
                    ]
                }
            ],
            "config-opts": [
                "-DBUILD_TESTING=OFF"
            ]
        }
    ]
}
